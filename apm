cmd_validate() {
    local id="${1:-}"
    _apm_require_agents_mode "validate"

    if [ -z "$APM_AGENTS_DB" ]; then
        apm_die 2 "No library path configured. Run: apm setup"
    fi

    if [ -n "$id" ]; then
        _apm_py validate-agent --id "$id" --db "$APM_AGENTS_DB"
        return $?
    else
        _apm_py validate-all --db "$APM_AGENTS_DB"
        return $?
    fi
}

cmd_list() {
    local query=""
    local force_global=0
    local force_project=0
    local filter_platform=""

    # Parse command-specific flags
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --global|-g) force_global=1; shift ;;
            --project)   force_project=1; shift ;;
            -a|--alias|--platform) 
                [ $# -lt 2 ] && apm_die 2 "$1 requires a value"
                filter_platform="$2"; shift 2 ;;
            -*)          shift ;; # skip other flags (might be global flags passed after cmd)
            *)           [ -z "$query" ] && query="$1"; shift ;;
        esac
    done

    # If scope overrides are requested, re-resolve temporarily
    local old_global_force="${APM_GLOBAL_FORCE:-0}"
    local old_runtime_dir="${APM_RUNTIME_DIR:-}"
    local old_scope="${APM_SCOPE:-}"

    if [ "$force_global" -eq 1 ]; then
        APM_GLOBAL_FORCE=1
        _apm_resolve_runtime_and_scope
    elif [ "$force_project" -eq 1 ]; then
        # Forcing project means ignoring global force if it was set
        APM_GLOBAL_FORCE=0
        _apm_resolve_runtime_and_scope
        if [ "$APM_SCOPE" != "project" ]; then
            apm_warn "Project scope requested but no local agents directory found."
        fi
    fi

    if [ -z "$APM_ACTIVE_DB" ]; then
        apm_die 2 "No library path configured. Run: apm setup"
    fi

    local out
    if [ "${APM_MODE}" = "skills" ]; then
        out=$(_apm_py status-skills --db "$APM_ACTIVE_DB" --platform "$APM_PLATFORM" --runtime-dir "$APM_RUNTIME_DIR")
    else
        out=$(_apm_py status-agents \
            --db "$APM_ACTIVE_DB" \
            --platform "$APM_PLATFORM" \
            --runtime-dir "$APM_RUNTIME_DIR")
    fi
    local exit_code=$?

    # Apply query and platform filter to the raw JSON (shared by both output modes)
    if [ -n "$query" ] || [ -n "$filter_platform" ]; then
        out=$(echo "$out" | python3 -c "
import json, sys
data = json.load(sys.stdin)
agents = data.get('agents', [])
query = '${query}'.lower()
fplat = '${filter_platform}'.lower()

if query:
    agents = [a for a in agents if
        query in str(a.get('id','') or '').lower() or
        query in str((a.get('root_meta') or {}).get('name','') or '').lower() or
        query in str((a.get('root_meta') or {}).get('description','') or '').lower() or
        query in str((a.get('deploy') or {}).get('name','') or '').lower() or
        query in str((a.get('deploy') or {}).get('description','') or '').lower()]

if fplat:
    def _has_deploy(a, platform):
        deploy = ((a.get('root_meta') or {}).get('deploy') or {})
        plat_block = deploy.get(platform) or {}
        if plat_block and plat_block.get('enabled', True) is not False:
            return True
        if platform == 'agents-dir':
            return any(isinstance(v, dict) and v.get('enabled', True) is not False
                       for v in deploy.values())
        return False
    agents = [a for a in agents if _has_deploy(a, fplat)]

data['agents'] = agents
print(json.dumps(data))
")
    fi

    if [ "$APM_JSON_MODE" = "1" ]; then
        echo "$out"
        # Restore state if changed
        APM_GLOBAL_FORCE="$old_global_force"
        APM_RUNTIME_DIR="$old_runtime_dir"
        APM_SCOPE="$old_scope"
        return $exit_code
    fi

    # Human-readable output matching TUI.md §9
    echo ""
    printf "  %-14s : %s\n" "Mode" "$APM_MODE"
    printf "  %-14s : %s\n" "Platform" "$APM_PLATFORM"
    printf "  %-14s : %s\n" "Scope" "$APM_SCOPE"
    printf "  %-14s : %s\n" "Library" "$APM_ACTIVE_DB"
    [ -n "$APM_RUNTIME_DIR" ] && printf "  %-14s : %s\n" "Runtime dir" "$APM_RUNTIME_DIR"
    [ -n "$APM_ACTIVE_GITHUB_MODE" ] && printf "  %-14s : %s\n" "GitHub mode" "$APM_ACTIVE_GITHUB_MODE"
    [ -n "$query" ] && printf "  %-14s : %s\n" "Query" "$query"
    [ -n "$filter_platform" ] && printf "  %-14s : %s\n" "Platform filter" "$filter_platform"
    echo ""
    echo "$out" | python3 -c "
import json, sys
data = json.load(sys.stdin)
agents = data.get('agents', [])

if not agents:
    if query:
        print(f\"  No ${APM_ACTIVE_KIND_PLURAL} found matching query: {query}\")
    else:
        print(\"  (no entries found)\")
    sys.exit(0)

# Sort order per TUI.md §9: invalid/collision, unmanaged, outdated, ready, orphan, installed, linked, no-deploy
ORDER = {
    'invalid': 0, 'collision': 1, 'unmanaged': 2, 'outdated': 3,
    'ready': 4, 'orphan': 5, 'installed': 6, 'linked': 7, 'no-deploy': 8,
}
agents.sort(key=lambda a: ORDER.get(a.get('state',{}).get('sync',''), 99))

symbols = {
    'installed':         '  ✓',
    'linked':            '  ⤷',
    'outdated':          '  ~',
    'ready':             '  ○',
    'no-deploy':         '  -',
    'orphan':            '  ?',
    'unmanaged':         '  !',
    'invalid':           '  x',
    'collision':         '  x',
}

tty = sys.stdout.isatty()
C = {
    'green':  '\033[32m'  if tty else '',
    'yellow': '\033[33m'  if tty else '',
    'cyan':   '\033[36m'  if tty else '',
    'red':    '\033[31m'  if tty else '',
    'bold':   '\033[1m'   if tty else '',
    'dim':    '\033[2m'   if tty else '',
    'reset':  '\033[0m'   if tty else '',
}
STATE_COLOR = {
    'installed':         C['green'],
    'linked':            C['green'],
    'outdated':          C['yellow'],
    'ready':             C['cyan'],
    'unmanaged':         C['yellow'],
    'invalid':           C['bold'] + C['red'],
    'orphan':            C['red'],
    'collision':         C['bold'] + C['red'],
    'no-deploy':         C['dim'],
}

show_cat = any(a.get('category') for a in agents)
for a in agents:
    sync  = a.get('state', {}).get('sync', '?')
    aid   = a.get('id', '?')
    cat   = a.get('category', '') or ''
    sym   = symbols.get(sync, '  ?')
    color = STATE_COLOR.get(sync, '')
    reset = C['reset'] if color else ''
    cat_col = f'  {cat:<16}' if show_cat else ''
    print(f'{color}{sym}  {aid:<28}{cat_col}  {sync}{reset}')
    "
    echo ""

    # Restore state
    APM_GLOBAL_FORCE="$old_global_force"
    APM_RUNTIME_DIR="$old_runtime_dir"
    APM_SCOPE="$old_scope"

    return $exit_code
    }
cmd_find() {
    local query="${1:-}"

    if [ -n "$query" ]; then
        cmd_list "$query"
        return $?
    fi

    # Interactive mode
    if [ -z "$APM_ACTIVE_DB" ]; then
        apm_die 2 "No library path configured. Run: apm setup"
    fi

    local _ids
    if [ "${APM_MODE}" = "skills" ]; then
        _ids=$(_apm_py list-skills --db "$APM_ACTIVE_DB" | python3 -c "import json,sys; d=json.load(sys.stdin); [print(a['id']) for a in d['skills']]")
    else
        _ids=$(_apm_py list-agents --db "$APM_ACTIVE_DB" | python3 -c "import json,sys; d=json.load(sys.stdin); [print(a['id']) for a in d['agents']]")
    fi
    
    if [ -z "$_ids" ]; then
        echo "  No ${APM_ACTIVE_KIND_PLURAL} found in library."
        return 0
    fi

    local _selected=""
    if command -v fzf >/dev/null 2>&1; then
        _selected=$(echo "$_ids" | fzf --header "Select a ${APM_ACTIVE_KIND} to view details" --height 40% --reverse)
    else
        # Fallback to numbered menu
        echo ""
        echo "  Select a ${APM_ACTIVE_KIND}:"
        local i=1
        local id_arr=()
        while IFS= read -r aid; do
            printf "  %2d) %s\n" "$i" "$aid"
            id_arr+=("$aid")
            i=$((i + 1))
        done <<< "$_ids"
        printf "  Choice [1-%d]: " "$((i - 1))"
        read -r _choice
        if [[ "$_choice" =~ ^[0-9]+$ ]] && [ "$_choice" -ge 1 ] && [ "$_choice" -lt "$i" ]; then
            _selected="${id_arr[$((_choice - 1))]}"
        fi
    fi

    if [ -n "$_selected" ]; then
        echo ""
        echo "  --- Details for $_selected ---"
        if [ "${APM_MODE}" = "skills" ]; then
            cmd_list "$_selected"
        else
            cmd_diff "$_selected"
        fi
    fi
}

cmd_check() {
    if [ "${APM_MODE}" = "skills" ]; then
        cmd_status
        return $?
    fi

    if [ -z "$APM_AGENTS_DB" ]; then
        apm_die 2 "No library path configured. Run: apm setup"
    fi

    local out
    out=$(_apm_py status-agents \
        --db "$APM_AGENTS_DB" \
        --platform "$APM_PLATFORM" \
        --runtime-dir "$APM_RUNTIME_DIR")
    
    echo ""
    echo "  Actionable Agents (outdated, unmanaged, ready):"
    echo ""
    echo "$out" | python3 -c "
import json, sys
data = json.load(sys.stdin)
agents = [a for a in data.get('agents', []) if a.get('state',{}).get('sync') in ('outdated', 'unmanaged', 'orphan', 'ready')]

if not agents:
    print(\"  Everything is installed or linked.\")
    sys.exit(0)

# Sort
ORDER = {'unmanaged': 0, 'outdated': 1, 'ready': 2, 'orphan': 3}
agents.sort(key=lambda a: ORDER.get(a.get('state',{}).get('sync',''), 99))

for a in agents:
    state = a.get('state',{}).get('sync')
    aid = a['id']
    print(f\"  [{state:<10}] {aid}\")

print()
print(f\"  Summary: {len([a for a in agents if a.get('state',{}).get('sync')=='outdated'])} outdated, {len([a for a in agents if a.get('state',{}).get('sync')=='unmanaged'])} unmanaged, {len([a for a in agents if a.get('state',{}).get('sync')=='ready'])} ready.\")
"
    echo ""
}

cmd_scan_external() {
    _apm_require_skills_mode "scan"

    if [ -z "$APM_SKILLS_DB" ]; then
        apm_die 2 "No skills library path configured. Run: apm setup"
    fi

    # Collect --dir flags; fall back to APM_SCAN_DIRS env, then ~/code/tools
    local scan_dirs=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dir|-d) [ $# -lt 2 ] && apm_die 2 "--dir requires a value"; scan_dirs+=("$2"); shift 2 ;;
            --max-depth) local _max_depth="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    if [ ${#scan_dirs[@]} -eq 0 ]; then
        if [ -n "${APM_SCAN_DIRS:-}" ]; then
            IFS=':' read -ra scan_dirs <<< "$APM_SCAN_DIRS"
        else
            scan_dirs=("$HOME/code/tools")
        fi
    fi

    local dirs_csv
    dirs_csv=$(IFS=','; echo "${scan_dirs[*]}")
    local max_depth="${_max_depth:-6}"

    local out
    out=$(_apm_py scan-external-skills \
        --scan-dirs "$dirs_csv" \
        --db "$APM_SKILLS_DB" \
        --max-depth "$max_depth")

    if [ "$APM_JSON_MODE" = "1" ]; then
        echo "$out"
        return 0
    fi

    echo ""
    printf "  %-14s : %s\n" "Mode" "skills / scan"
    printf "  %-14s : %s\n" "Scan dirs" "$dirs_csv"
    printf "  %-14s : %s\n" "Skills DB" "$APM_SKILLS_DB"
    echo ""

    echo "$out" | python3 -c "
import json, sys
data = json.load(sys.stdin)
results = data.get('results', [])
summary = data.get('summary', {})

tty = sys.stdout.isatty()
C = {
    'green':  '\033[32m'  if tty else '',
    'yellow': '\033[33m'  if tty else '',
    'cyan':   '\033[36m'  if tty else '',
    'dim':    '\033[2m'   if tty else '',
    'bold':   '\033[1m'   if tty else '',
    'reset':  '\033[0m'   if tty else '',
}

STATUS_SYM = {
    'unmanaged':      ('  ○', C['cyan']),
    'managed-copy':   ('  ~', C['yellow']),
    'managed-symlink':('  ⤷', C['green']),
}

if not results:
    print('  No SKILL.md files found in scan dirs.')
else:
    unmanaged   = [r for r in results if r['db_status'] == 'unmanaged']
    copies      = [r for r in results if r['db_status'] == 'managed-copy']
    symlinked   = [r for r in results if r['db_status'] == 'managed-symlink']

    sections = [
        ('Unmanaged (not in skills DB)', unmanaged),
        ('Managed as copy (could be symlink)', copies),
        ('Managed as symlink', symlinked),
    ]
    for heading, items in sections:
        if not items:
            continue
        print(f'  {C[\"bold\"]}{heading}{C[\"reset\"]}')
        for r in items:
            sym, col = STATUS_SYM.get(r['db_status'], ('  ?', ''))
            cid  = r['candidate_id']
            tool = r['source_tool']
            amb  = ' (ambiguous id)' if r.get('ambiguous') else ''
            name = r.get('name') or ''
            match = f'  -> db:{r[\"db_match_id\"]}' if r.get('db_match_id') else ''
            label = name if name and name != cid else ''
            label_str = f'  {C[\"dim\"]}{label}{C[\"reset\"]}' if label else ''
            print(f'{col}{sym}  {cid:<30}{C[\"reset\"]}  [{tool}]{amb}{match}{label_str}')
        print()

print(f'  Summary: {summary.get(\"unmanaged\",0)} unmanaged, '
      f'{summary.get(\"managed_copy\",0)} managed-copy, '
      f'{summary.get(\"managed_symlink\",0)} managed-symlink  '
      f'({summary.get(\"total\",0)} total)')
"
    echo ""
}

cmd_scan_autofix() {
    _apm_require_skills_mode "scan autofix"

    if [ -z "$APM_SKILLS_DB" ]; then
        apm_die 2 "No skills library path configured. Run: apm setup"
    fi

    # Collect same --dir flags as cmd_scan_external
    local scan_dirs=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dir|-d) [ $# -lt 2 ] && apm_die 2 "--dir requires a value"; scan_dirs+=("$2"); shift 2 ;;
            --max-depth) local _max_depth="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    if [ ${#scan_dirs[@]} -eq 0 ]; then
        if [ -n "${APM_SCAN_DIRS:-}" ]; then
            IFS=':' read -ra scan_dirs <<< "$APM_SCAN_DIRS"
        else
            scan_dirs=("$HOME/code/tools")
        fi
    fi

    local dirs_csv
    dirs_csv=$(IFS=','; echo "${scan_dirs[*]}")
    local max_depth="${_max_depth:-6}"

    # Run scan and extract managed-copy entries as JSON array
    local scan_out
    scan_out=$(_apm_py scan-external-skills \
        --scan-dirs "$dirs_csv" \
        --db "$APM_SKILLS_DB" \
        --max-depth "$max_depth")

    local copies_json
    copies_json=$(echo "$scan_out" | python3 -c "
import json, sys
data = json.load(sys.stdin)
copies = [r for r in data.get('results', []) if r['db_status'] == 'managed-copy']
print(json.dumps(copies))
")

    local count
    count=$(echo "$copies_json" | python3 -c "import json,sys; print(len(json.load(sys.stdin)))")

    echo ""
    printf "  %-14s : %s\n" "Mode" "skills / scan autofix"
    printf "  %-14s : %s\n" "Scan dirs" "$dirs_csv"
    printf "  %-14s : %s\n" "Skills DB" "$APM_SKILLS_DB"
    echo ""

    if [ "$count" -eq 0 ]; then
        echo "  No managed-copy skills found — nothing to fix."
        echo ""
        return 0
    fi

    echo "  The following skills_db entries are plain copies of an external source."
    echo "  Autofix will back up each entry and replace it with a symlink."
    echo ""

    echo "$copies_json" | python3 -c "
import json, sys
copies = json.load(sys.stdin)
for r in copies:
    print(f'  ~ {r[\"db_match_id\"]:<30}  {r[\"skill_dir\"]} -> {r[\"db_match_id\"]}')
    print(f'    source : {r[\"skill_dir\"]}')
"
    echo ""

    if [ "$APM_DRY_RUN" = "1" ]; then
        echo "  (dry run — nothing changed)"
        echo ""
        return 0
    fi

    if [ "$APM_FORCE" != "1" ]; then
        printf "  Convert %s entr%s to symlink(s)? [y/N] " \
            "$count" "$([ "$count" -eq 1 ] && echo y || echo ies)"
        read -r _confirm
        case "$_confirm" in
            [yY]*) ;;
            *) echo "  Cancelled."; echo ""; return 0 ;;
        esac
    fi

    local timestamp
    timestamp=$(date -u +%Y%m%d-%H%M%S)
    local backups_dir="${APM_SKILLS_DB}/_backups"
    apm_ensure_dir "$backups_dir" || apm_die 2 "Cannot create backups dir: $backups_dir"

    apm_acquire_lock "library"

    local fixed=0 failed=0

    while IFS= read -r entry_json; do
        local db_id skill_dir
        db_id=$(echo "$entry_json"    | python3 -c "import json,sys; print(json.load(sys.stdin)['db_match_id'])")
        skill_dir=$(echo "$entry_json" | python3 -c "import json,sys; print(json.load(sys.stdin)['skill_dir'])")

        local db_entry="${APM_SKILLS_DB}/${db_id}"
        local backup_path="${backups_dir}/${db_id}.apm-backup-${timestamp}"

        printf "  %-12s : %s\n" "Fixing" "$db_id"

        # Safety: db_entry must exist and be a real directory (not already a symlink)
        if [ ! -d "$db_entry" ]; then
            apm_warn "  Skipping $db_id — not found at $db_entry"
            (( failed++ )) || true
            continue
        fi
        if [ -L "$db_entry" ]; then
            apm_warn "  Skipping $db_id — already a symlink"
            (( failed++ )) || true
            continue
        fi
        # skill_dir must still exist (tool source)
        if [ ! -d "$skill_dir" ]; then
            apm_warn "  Skipping $db_id — source no longer exists: $skill_dir"
            (( failed++ )) || true
            continue
        fi

        # Backup
        if ! cp -r "$db_entry" "$backup_path"; then
            apm_release_lock "library"
            apm_die 2 "Failed to back up $db_entry to $backup_path"
        fi
        printf "  %-12s : %s\n" "Backup" "$backup_path"

        # Replace with symlink
        if ! rm -rf "$db_entry"; then
            apm_release_lock "library"
            apm_die 2 "Failed to remove $db_entry after backup"
        fi
        if ! ln -sfn "$skill_dir" "$db_entry"; then
            # Attempt restore
            cp -r "$backup_path" "$db_entry" 2>/dev/null
            apm_release_lock "library"
            apm_die 2 "Failed to create symlink $db_entry -> $skill_dir (restored from backup)"
        fi

        printf "  %-12s : %s -> %s\n" "Linked" "$db_entry" "$skill_dir"
        echo ""
        (( fixed++ )) || true

    done < <(echo "$copies_json" | python3 -c "
import json, sys
for r in json.load(sys.stdin):
    print(json.dumps(r))
")

    apm_release_lock "library"

    if [ "$APM_JSON_MODE" = "1" ]; then
        python3 -c "import json; print(json.dumps({'command':'scan autofix','fixed':${fixed},'failed':${failed},'timestamp':'${timestamp}'}))"
    else
        echo "  Done. $fixed fixed, $failed skipped."
        echo ""
    fi
}

cmd_skill_duplicates() {
    _apm_require_skills_mode "duplicates"

    if [ -z "$APM_SKILLS_DB" ]; then
        apm_die 2 "No skills library path configured. Run: apm setup"
    fi

    local out
    out=$(_apm_py find-skill-duplicates --db "$APM_SKILLS_DB")

    if [ "$APM_JSON_MODE" = "1" ]; then
        echo "$out"
        return 0
    fi

    echo ""
    printf "  %-14s : %s\n" "Mode" "skills / duplicates"
    printf "  %-14s : %s\n" "Skills DB" "$APM_SKILLS_DB"
    echo ""

    echo "$out" | python3 -c "
import json, sys
data = json.load(sys.stdin)
groups   = data.get('duplicate_groups', [])
cands    = data.get('symlink_candidates', [])
summary  = data.get('summary', {})

tty = sys.stdout.isatty()
C = {
    'yellow': '\033[33m' if tty else '',
    'cyan':   '\033[36m' if tty else '',
    'bold':   '\033[1m'  if tty else '',
    'dim':    '\033[2m'  if tty else '',
    'reset':  '\033[0m'  if tty else '',
}

if groups:
    print(f'  {C[\"bold\"]}Duplicate groups (identical content){C[\"reset\"]}')
    for g in groups:
        kind = g.get('kind', '')
        ids  = g.get('ids', [])
        dirs = g.get('skill_dirs', [])
        print(f'  {C[\"yellow\"]}~{C[\"reset\"]}  {kind}')
        for sid, sd in zip(ids, dirs):
            rp = ''
            rps = g.get('real_paths', [])
            if rps:
                rp = f'  -> {rps[ids.index(sid)]}' if rps[ids.index(sid)] else ''
            print(f'       {sid:<30}  {C[\"dim\"]}{sd}{rp}{C[\"reset\"]}')
    print()

if cands:
    print(f'  {C[\"bold\"]}Symlink candidates (copy matches a symlinked source){C[\"reset\"]}')
    print(f'  {C[\"dim\"]}These entries are plain copies; consider converting to symlinks.{C[\"reset\"]}')
    print(f'  {C[\"dim\"]}Run: apm --mode skills scan autofix  to convert copies to symlinks{C[\"reset\"]}')
    print()
    for c in cands:
        print(f'  {C[\"cyan\"]}~{C[\"reset\"]}  {c[\"db_id\"]:<30}  copy of -> {c[\"symlink_db_id\"]}')
        print(f'       skill_dir  : {c[\"skill_dir\"]}')
        print(f'       source     : {c[\"matching_real_path\"]}')
    print()

if not groups and not cands:
    print('  No duplicates found.')
    print()

print(f'  Summary: {summary.get(\"duplicate_groups\",0)} duplicate group(s), '
      f'{summary.get(\"symlink_candidates\",0)} symlink candidate(s)  '
      f'({summary.get(\"total_skills\",0)} skills total)')
"
    echo ""
}

