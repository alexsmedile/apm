cmd_rtui() {
    if [ -z "$APM_ACTIVE_DB" ]; then
        if [ ! -f "${APM_CONFIG_DIR}/config.sh" ]; then
            echo ""
            echo "No config found at ${APM_CONFIG_DIR}/config.sh"
            echo ""
            cmd_setup
            apm_load_config
            apm_apply_cli_overrides
        else
            apm_die 2 "No library path configured. Run: apm setup"
        fi
    fi

    local _bin
    _bin="${APM_SCRIPT_DIR}/lib/rust/apm-tui/target/release/apm-tui"
    if [ ! -x "$_bin" ]; then
        _bin="${APM_SCRIPT_DIR}/lib/rust/apm-tui/target/debug/apm-tui"
    fi
    if [ ! -x "$_bin" ]; then
        apm_die 3 "apm-tui binary not found. Build it with: cd ${APM_SCRIPT_DIR}/lib/rust/apm-tui && cargo build --release"
    fi

    APM_TUI_MODE="${APM_MODE}" \
    APM_TUI_DEFAULT_MODE="${APM_DEFAULT_MODE}" \
    APM_TUI_AGENTS_DB="${APM_AGENTS_DB}" \
    APM_TUI_SKILLS_DB="${APM_SKILLS_DB}" \
    APM_TUI_PLATFORM="${APM_PLATFORM}" \
    APM_TUI_SCOPE="${APM_SCOPE}" \
    APM_TUI_RUNTIME_DIR="${APM_RUNTIME_DIR}" \
    APM_TUI_AGENTS_GITHUB_MODE="${APM_GITHUB_MODE}" \
    APM_TUI_SKILLS_GITHUB_MODE="${APM_SKILLS_GITHUB_MODE}" \
    APM_PYTHON_HELPER="${APM_LIB_PY}/apm_python.py" \
    APM_BIN="${APM_SCRIPT_DIR}/apm" \
    exec "$_bin"
}

# ---------------------------------------------------------------------------
# Main entrypoint
# ---------------------------------------------------------------------------

main() {
    # Parse global flags first, leaving command + its args in _REMAINING_ARGS
    _apm_parse_global_flags "$@"

    # Load config (file → env → cli overrides)
    apm_load_config
    apm_apply_cli_overrides

    # Check dependencies (skip for setup and help)
    local cmd="${_REMAINING_ARGS[0]:-}"
    if [ "$cmd" != "setup" ] && [ "$cmd" != "--help" ] && [ "$cmd" != "-h" ] && [ "$cmd" != "--version" ] && [ "$cmd" != "-V" ] && [ "$cmd" != "version" ]; then
        _apm_check_deps
    fi

    # Dispatch
    case "$cmd" in
        skills)
            # positional shortcut: apm skills <subcmd> [args] — re-invoke with -s injected
            shift_args=("${_REMAINING_ARGS[@]:1}")
            exec "$0" -s "${shift_args[@]}"
            ;;
        agents)
            # positional shortcut: apm agents <subcmd> [args] — re-invoke with -a injected
            shift_args=("${_REMAINING_ARGS[@]:1}")
            exec "$0" -a "${shift_args[@]}"
            ;;
        setup)
            cmd_setup
            ;;
        init)
            _apm_require_agents_mode "init"
            cmd_init "${_REMAINING_ARGS[@]:1}"
            ;;
        config)
            cmd_config
            ;;
        validate)
            cmd_validate "${_REMAINING_ARGS[1]:-}"
            ;;
        list|ls)
            cmd_list "${_REMAINING_ARGS[@]:1}"
            ;;
        find)
            cmd_find "${_REMAINING_ARGS[1]:-}"
            ;;
        status)
            cmd_status
            ;;
        check)
            cmd_check
            ;;
        diff)
            cmd_diff "${_REMAINING_ARGS[1]:-}"
            ;;
        install)
            cmd_install "${_REMAINING_ARGS[@]:1}"
            ;;
        remove|rm)
            cmd_remove "${_REMAINING_ARGS[1]:-}"
            ;;
        update)
            _apm_require_agents_mode "update"
            cmd_update "${_REMAINING_ARGS[1]:-}"
            ;;
        import)
            _apm_require_agents_mode "import"
            cmd_import "${_REMAINING_ARGS[@]:1}"
            ;;
        link)
            _apm_require_agents_mode "link"
            cmd_link "${_REMAINING_ARGS[@]:1}"
            ;;
        unlink)
            _apm_require_agents_mode "unlink"
            cmd_unlink "${_REMAINING_ARGS[@]:1}"
            ;;
        links)
            _apm_require_agents_mode "links"
            cmd_links "${_REMAINING_ARGS[1]:-}"
            ;;
        scan)
            if [ "${_REMAINING_ARGS[1]:-}" = "autofix" ]; then
                cmd_scan_autofix "${_REMAINING_ARGS[@]:2}"
            else
                cmd_scan_external "${_REMAINING_ARGS[@]:1}"
            fi
            ;;
        duplicates)
            cmd_skill_duplicates
            ;;
        github)
            cmd_github "${_REMAINING_ARGS[@]:1}"
            ;;
        tui|btui)
            cmd_tui
            ;;
        rtui)
            cmd_rtui
            ;;
        version|--version|-V)
            echo "apm $APM_VERSION"
            ;;
        --help|-h|help)
            echo "apm $APM_VERSION — local-first package manager for AI agent prompt files"
            cat <<'HELP'

Usage:
  apm [flags] <command> [args]

Global flags:
  --skills, -s                   Shorthand for --mode skills
  --agents, -a                   Shorthand for --mode agents
  --mode <name>                  Select mode: agents | skills
  --platform <names>, -p <names> Platform(s), comma-separated; overrides default-platforms for this run
                                 Full: claude-code, cursor, codex, gemini, windsurf, continue, agents-dir, generic
                                 Short: cc, crs, cdx, gmn, wds, cnt, agt, gen
  --json, -j                     Machine-readable JSON output
  --force, -f                    Skip confirmation prompts
  --dry-run                      Show what would happen without writing anything
  --global, -g                   Force global scope (ignore local .claude/ etc)
  --cwd <path>                   Force project scope rooted at a specific folder
  --install-mode <mode>          Override install mode for this run: copy | symlink
  --db <path>                    Override library database path

Commands:
  setup                        Configure apm (interactive wizard)
  init [--platform <name>]     Initialize local project scope
  config                       Show resolved configuration
  validate [id]                Validate agent(s) in the library (agents mode)
  list [query] [--global|--project] [-a <platform>] List active mode entries with sync state (alias: ls)
  find [query]                 Search the active mode library
  status                       Show counts by sync state
  check                        Show summary of actionable entries
  diff <id>                    Show diff between library and runtime (agents mode)
  install <id> [id…]           Install one or more agents, or in skills mode create skill symlinks
  install --all                Install all ready/outdated agents or skills
  install --cat <name>         Install all agents in a category
  remove <id>                  Remove agent runtime file or skill symlink (alias: rm)
  update [id]                  Reinstall outdated agents (all if no id given)
  import                       Pick from unmanaged runtime agents (interactive)
  import [id]                  Import specific agent, or --all for everything
  link <id> [--as <alias>] [--project|--global]   Symlink agent split file into runtime dir
  unlink <id> [--project|--global|--all]           Remove symlink(s) for an agent
  links [id]                   List tracked symlinks (all agents or one)
  scan [--dir <path>] …        Scan directories for SKILL.md files not yet in the library (skills mode)
  scan autofix [--dir <path>]  Convert managed-copy skills to symlinks pointing at their source (skills mode)
  duplicates                   Find duplicate or copy-of-symlink skills in the library (skills mode)
  github <sub>                 GitHub sync (connect, status, diff, push, pull)
  btui                         Launch the bash/Python TUI (legacy fallback, alias: tui)
  rtui                         Launch the Ratatui TUI (build first: cd lib/rust/apm-tui && cargo build --release)
  version                      Show apm version

Run with no command for interactive mode.
HELP
            ;;
        "")
            cmd_rtui
            ;;
        *)
            apm_die 2 "Unknown command: $cmd. Run 'apm --help' for usage."
            ;;
    esac
}

main "$@"
