#!/usr/bin/env bash
# apm — local-first package manager for AI agent prompt files
# See PLAN.md and SPEC_*.md for full specification

APM_VERSION="0.1.0"

set -uo pipefail

# Resolve script location for lib paths (follow symlinks so lib/ is found correctly)
_apm_src="${BASH_SOURCE[0]}"
while [ -L "$_apm_src" ]; do _apm_src="$(readlink "$_apm_src")"; done
APM_SCRIPT_DIR="$(cd "$(dirname "$_apm_src")" && pwd)"
unset _apm_src
APM_LIB_SHELL="${APM_SCRIPT_DIR}/lib/shell"
APM_LIB_PY="${APM_SCRIPT_DIR}/lib/py"

# Source shell libraries
source "${APM_LIB_SHELL}/ui.shlib"
source "${APM_LIB_SHELL}/config.shlib"
source "${APM_LIB_SHELL}/locks.shlib"
source "${APM_LIB_SHELL}/fs.shlib"

# ---------------------------------------------------------------------------
# Dependency checks
# ---------------------------------------------------------------------------

_apm_check_deps() {
    if ! command -v python3 >/dev/null 2>&1; then
        apm_die 3 "python3 is required but not found. Please install Python 3."
    fi

    if ! python3 -c "import yaml" 2>/dev/null; then
        apm_die 3 "PyYAML is required but not installed. Run: pip3 install pyyaml"
    fi
}

# ---------------------------------------------------------------------------
# Python helper invocation
# ---------------------------------------------------------------------------

# Call the Python helper and return its output.
# Shell passes structured args; Python returns JSON.
_apm_py() {
    python3 "${APM_LIB_PY}/apm_python.py" "$@"
}

# ---------------------------------------------------------------------------
# Global flag parsing
# ---------------------------------------------------------------------------

_CLI_DB=""
_CLI_MODE=""
_CLI_PLATFORM=""
_CLI_INSTALL_MODE=""
_CLI_PROJECT_DIR=""
: "${APM_JSON_MODE:=0}"
: "${APM_DRY_RUN:=0}"
: "${APM_FORCE:=0}"
: "${APM_GLOBAL_FORCE:=0}"

_apm_parse_global_flags() {
    local _pos_args=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --db)
                [ $# -lt 2 ] && apm_die 2 "--db requires a value"
                _CLI_DB="$2"; shift 2 ;;
            --platform|-p)
                [ $# -lt 2 ] && apm_die 2 "${1} requires a value"
                _CLI_PLATFORM="$2"; shift 2 ;;
            --mode)
                [ $# -lt 2 ] && apm_die 2 "--mode requires a value (agents|skills)"
                _CLI_MODE="$2"; shift 2 ;;
            --skills|-s)     _CLI_MODE="skills"; shift ;;
            --agents|-a)     _CLI_MODE="agents"; shift ;;
            --cwd|--project-dir)
                [ $# -lt 2 ] && apm_die 2 "${1} requires a value"
                _CLI_PROJECT_DIR="$2"; shift 2 ;;
            --json|-j)       APM_JSON_MODE=1; export APM_JSON_MODE; shift ;;
            --dry-run)       APM_DRY_RUN=1; export APM_DRY_RUN; shift ;;
            --force|-f)      APM_FORCE=1; export APM_FORCE; shift ;;
            --global|-g)     APM_GLOBAL_FORCE=1; export APM_GLOBAL_FORCE; shift ;;
            --install-mode)
                [ $# -lt 2 ] && apm_die 2 "--install-mode requires a value (copy|symlink)"
                _CLI_INSTALL_MODE="$2"; shift 2 ;;
            *)
                _pos_args+=("$1")
                shift ;;
        esac
    done
    _REMAINING_ARGS=("${_pos_args[@]+"${_pos_args[@]}"}")
}

_apm_require_agents_mode() {
    if [ "${APM_MODE:-agents}" != "agents" ]; then
        apm_die 2 "Command '${1:-this command}' is only supported in agents mode"
    fi
}

_apm_title_case_active_kind() {
    case "${APM_ACTIVE_KIND:-agent}" in
        skill) echo "Skill" ;;
        *)     echo "Agent" ;;
    esac
}

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

cmd_setup() {
    apm_acquire_lock "config"
    apm_setup_wizard
    local _wizard_status=$?
    apm_release_lock "config"
    return $_wizard_status
}

cmd_init() {
    local target_plat="${APM_PLATFORM}"
    local target_root="${APM_PROJECT_DIR:-.}"
    
    # Parse --platform if provided
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --platform) [ $# -lt 2 ] && apm_die 2 "--platform requires a value"; target_plat="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    local old_platform="${APM_PLATFORM}"
    APM_PLATFORM="$target_plat"
    local local_dir=""
    local_dir="$(_apm_project_runtime_dir_for_root "$target_root")" || local_dir=""
    APM_PLATFORM="$old_platform"

    [ -z "$local_dir" ] && apm_die 2 "Initialization not supported for platform: $target_plat"

    echo ""
    echo "  Initializing project scope for platform: $target_plat"
    [ "$target_root" != "." ] && echo "  Project root: $target_root"
    echo "  Target directory: $local_dir"
    echo ""

    if [ -d "$local_dir" ]; then
        echo "  Directory already exists. Nothing to do."
        echo ""
        return 0
    fi

    if [ "$APM_FORCE" != "1" ]; then
        printf "  Create this directory? [y/N] "
        read -r _confirm
        case "$_confirm" in
            [yY]*) ;;
            *) echo "  Cancelled."; echo ""; return 0 ;;
        esac
    fi

    mkdir -p "$local_dir" || apm_die 2 "Failed to create directory: $local_dir"
    
    echo ""
    echo "  Success! apm will now use project scope for $target_plat in this directory."
    echo "  To force global scope later, use the -g or --global flag."
    echo ""
}

