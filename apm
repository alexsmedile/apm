    _apm_py status-skills \
        --db "$APM_SKILLS_DB" \
        --platform "$APM_PLATFORM" \
        --runtime-dir "$APM_RUNTIME_DIR"
}

_apm_skill_field_from_status() {
    local id="$1"
    local field="$2"
    local status_json="$3"
    echo "$status_json" | python3 -c "
import json, sys
skill_id = sys.argv[1]
field = sys.argv[2]
data = json.load(sys.stdin)
for s in data.get('skills', []):
    if s.get('id') == skill_id:
        value = s
        for part in field.split('.'):
            value = (value or {}).get(part, '')
