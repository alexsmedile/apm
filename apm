_apm_interactive_note() {
    APM_INTERACTIVE_MESSAGE="${1:-}"
    export APM_INTERACTIVE_MESSAGE
}

_apm_interactive_move_selection() {
    local delta="$1"
    local tab current ids idx current_idx new_idx
    local -a arr=()

    tab="$(_apm_interactive_active_tab)"
    ids="$(_apm_interactive_get_visible_ids "$tab")"
    [ -z "$ids" ] && return 0

    IFS='|' read -r -a arr <<< "$ids"
    [ "${#arr[@]}" -eq 0 ] && return 0

    current="$(_apm_interactive_get_selected_id "$tab")"
    current_idx=0
    for idx in "${!arr[@]}"; do
        if [ "${arr[$idx]}" = "$current" ]; then
            current_idx=$idx
            break
        fi
    done

    new_idx=$((current_idx + delta))
    [ "$new_idx" -lt 0 ] && new_idx=0
    [ "$new_idx" -ge "${#arr[@]}" ] && new_idx=$((${#arr[@]} - 1))
    _apm_interactive_set_selected_id "$tab" "${arr[$new_idx]}"
}

_apm_interactive_pause() {
    printf "\nPress any key to return..."
    read -rsn1 _ || true
}

_apm_interactive_run_selected_action() {
    local action="$1"
    local tab id ec=0

    tab="$(_apm_interactive_active_tab)"
    id="$(_apm_interactive_get_selected_id "$tab")"

    if [ -z "$id" ]; then
        _apm_interactive_note "No ${tab%?} selected"
        return 0
    fi

    case "$tab:$action" in
        agents:inspect)
            cmd_list "$id"
            ec=$?
            _apm_interactive_pause
            ;;
        agents:install)
            cmd_install "$id"
            ec=$?
            ;;
        agents:update)
            cmd_update "$id"
            ec=$?
            ;;
        agents:remove)
            cmd_remove "$id"
            ec=$?
            ;;
        agents:diff)
            cmd_diff "$id"
            ec=$?
            _apm_interactive_pause
            ;;
        agents:link)
            cmd_link "$id"
            ec=$?
            ;;
        agents:unlink)
            cmd_unlink "$id"
            ec=$?
            ;;
        agents:github-diff)
            cmd_github diff "$id"
            ec=$?
            _apm_interactive_pause
            ;;
        agents:github-push)
            cmd_github push "$id"
            ec=$?
            ;;
        agents:github-pull)
            cmd_github pull "$id"
            ec=$?
            ;;
        *)
            _apm_interactive_note "No direct action for ${tab}"
            return 0
            ;;
    esac

    if [ "$ec" -eq 0 ]; then
        case "$action" in
            inspect) _apm_interactive_note "Viewed ${id}" ;;
            diff) _apm_interactive_note "Diff checked for ${id}" ;;
            github-diff) _apm_interactive_note "GitHub diff checked for ${id}" ;;
            github-push) _apm_interactive_note "Pushed ${id}" ;;
            github-pull) _apm_interactive_note "Pulled ${id}" ;;
            *) _apm_interactive_note "${action} completed for ${id}" ;;
        esac
    else
        _apm_interactive_note "${action} failed for ${id}"
    fi
}

