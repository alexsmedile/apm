_apm_interactive_exec_command() {
    local _line="$1"
    _line="${_line#"${_line%%[![:space:]]*}"}"
    [ -z "$_line" ] && return 0

    local _icmd _iargs
    _icmd="${_line%% *}"
    _iargs=""
    [ "${_line}" != "${_icmd}" ] && _iargs="${_line#* }"

    case "$_icmd" in
        quit|exit|q)
            echo ""
            return 10 ;;
        mode)
            if [ "$_iargs" = "agents" ] || [ "$_iargs" = "skills" ]; then
                _apm_interactive_set_tab "$_iargs"
            elif [ "$_iargs" = "settings" ]; then
                _apm_interactive_set_tab "settings"
            else
                echo "  Usage: mode <agents|skills|settings>"
                sleep 1
            fi ;;
        list|ls)
            cmd_list "$_iargs"
            printf "\nPress any key to return..."
            read -rsn1 _ ;;
        find)
            cmd_find "$_iargs"
            printf "\nPress any key to return..."
            read -rsn1 _ ;;
        status)
            cmd_status
            printf "\nPress any key to return..."
            read -rsn1 _ ;;
        check)
            cmd_check
            printf "\nPress any key to return..."
            read -rsn1 _ ;;
        diff)
            [ -z "$_iargs" ] && { echo "  Usage: diff <id>"; sleep 1; return 0; }
            cmd_diff "$_iargs"
            printf "\nPress any key to return..."
            read -rsn1 _ ;;
        install)
            [ -z "$_iargs" ] && { echo "  Usage: install <id|--all|--cat <category>>"; sleep 1; return 0; }
            # shellcheck disable=SC2086
            cmd_install $_iargs ;;
        remove|rm)
            [ -z "$_iargs" ] && { echo "  Usage: remove <id>"; sleep 1; return 0; }
            cmd_remove "$_iargs" ;;
        update)
            cmd_update "$_iargs" ;;
        import)
            # shellcheck disable=SC2086
            cmd_import $_iargs ;;
        link)
            [ -z "$_iargs" ] && { echo "  Usage: link <id> [--as <alias>] [--project|--global]"; sleep 1; return 0; }
            # shellcheck disable=SC2086
            cmd_link $_iargs ;;
        unlink)
            [ -z "$_iargs" ] && { echo "  Usage: unlink <id> [--project|--global|--all]"; sleep 1; return 0; }
            # shellcheck disable=SC2086
            cmd_unlink $_iargs ;;
        links)
            cmd_links "$_iargs"
            printf "\nPress any key to return..."
            read -rsn1 _ ;;
        validate)
            cmd_validate "$_iargs"
            printf "\nPress any key to return..."
            read -rsn1 _ ;;
        github)
            # shellcheck disable=SC2086
            cmd_github $_iargs
            printf "\nPress any key to return..."
            read -rsn1 _ ;;
        config)
            cmd_config
            printf "\nPress any key to return..."
            read -rsn1 _ ;;
        setup)
            cmd_setup
            apm_load_config
            apm_apply_cli_overrides
            _apm_interactive_set_tab "${APM_MODE}" ;;
        refresh|r)
            ;;
        help|h|\?)
            echo ""
            echo "  Tabs"
            echo "  Tab cycles tabs, 1 opens agents, 2 opens skills, S opens settings."
            echo ""
            echo "  Commands"
            echo "  Press : to enter a command line."
            echo "  mode <agents|skills|settings>"
            echo "  list  find  status  check  github <sub>  config  setup"
            echo "  both modes: install remove"
            echo "  agents-only: diff update import link unlink links validate"
            printf "\nPress any key to return..."
            read -rsn1 _ ;;
        *)
            echo "  Unknown command: $_icmd"
            sleep 1 ;;
    esac
    return 0
}

cmd_interactive() {
    if [ -z "$APM_ACTIVE_DB" ]; then
        if [ ! -f "${APM_CONFIG_DIR}/config.sh" ]; then
            echo ""
            echo "No config found at ${APM_CONFIG_DIR}/config.sh"
            echo ""
            cmd_setup
            # Reload config after setup
            apm_load_config
            apm_apply_cli_overrides
        else
            apm_die 2 "No library path configured. Run: apm setup"
        fi
    fi

    # If stdin is not a terminal, just print the dashboard and exit (non-interactive)
    if [ ! -t 0 ]; then
        _apm_interactive_dashboard
        return 0
    fi

    _apm_interactive_set_tab "${APM_MODE}"
    _apm_interactive_init_view_state

    while true; do
        local _key
        _apm_interactive_render_screen
        IFS= read -rsn1 _key || break

        case "$_key" in
            $'\t')
                _apm_interactive_next_tab ;;
            1)
                _apm_interactive_set_tab "agents" ;;
            2)
                _apm_interactive_set_tab "skills" ;;
            S)
                _apm_interactive_set_tab "settings" ;;
            e)
                if [ "${APM_INTERACTIVE_SHOW_ALL:-0}" = "1" ]; then
                    APM_INTERACTIVE_SHOW_ALL=0
                else
                    APM_INTERACTIVE_SHOW_ALL=1
                fi ;;
            d)
                if [ "${APM_INTERACTIVE_SHOW_NO_DEPLOY:-0}" = "1" ]; then
                    APM_INTERACTIVE_SHOW_NO_DEPLOY=0
                else
                    APM_INTERACTIVE_SHOW_NO_DEPLOY=1
                fi ;;
            /)
                printf "\nfilter> "
                read -r APM_INTERACTIVE_FILTER || break
                _apm_interactive_note "Filter updated"
                ;;
            :)
                printf "\ncommand> "
                local _line=""
                read -r _line || break
                _apm_interactive_exec_command "$_line"
                [ $? -eq 10 ] && break ;;
            q)
                echo ""
                break ;;
            s)
                cmd_status
                _apm_interactive_pause ;;
            h|\?)
                _apm_interactive_exec_command "help" ;;
        esac
    done

    echo "Bye."
    echo ""
}

cmd_tui() {
    if [ -z "$APM_ACTIVE_DB" ]; then
        if [ ! -f "${APM_CONFIG_DIR}/config.sh" ]; then
            echo ""
