_apm_interactive_render_entity_tab() {
    local out
    if [ "${APM_MODE}" = "skills" ]; then
        out=$(_apm_py status-skills --db "$APM_ACTIVE_DB" --platform "$APM_PLATFORM" --runtime-dir "$APM_RUNTIME_DIR" 2>/dev/null) || {
            apm_warn "Could not load skill status"
            return 1
        }
    else
        out=$(_apm_py status-agents \
            --db "$APM_ACTIVE_DB" \
            --platform "$APM_PLATFORM" \
            --runtime-dir "$APM_RUNTIME_DIR" 2>/dev/null) || {
            apm_warn "Could not load agent status"
            return 1
        }
    fi

    printf '%s\n' "$out" | python3 -c "
import json, sys
import os
data = json.load(sys.stdin)
items = data.get('agents') or data.get('skills') or []
mode = '$APM_MODE'
platform = '$APM_PLATFORM'
scope = '$APM_SCOPE'
db = '$APM_ACTIVE_DB'
runtime = '$APM_RUNTIME_DIR'
gh_mode = '$APM_ACTIVE_GITHUB_MODE'
label = 'Agents' if mode == 'agents' else 'Skills'
show_all = os.environ.get('APM_INTERACTIVE_SHOW_ALL', '0') == '1'
show_no_deploy = os.environ.get('APM_INTERACTIVE_SHOW_NO_DEPLOY', '0') == '1'
limit = int(os.environ.get('APM_INTERACTIVE_LIMIT', '12') or '12')
query = os.environ.get('APM_INTERACTIVE_FILTER', '').strip().lower()

C = {
  'reset': os.environ.get('APM_TUI_RESET', ''),
  'bold': os.environ.get('APM_TUI_BOLD', ''),
  'dim': os.environ.get('APM_TUI_DIM', ''),
  'green': os.environ.get('APM_TUI_GREEN', ''),
  'yellow': os.environ.get('APM_TUI_YELLOW', ''),
  'cyan': os.environ.get('APM_TUI_CYAN', ''),
  'red': os.environ.get('APM_TUI_RED', ''),
}

order = {
  'invalid': 0, 'collision': 1, 'unmanaged': 2, 'outdated': 3,
  'ready': 4, 'orphan': 5, 'installed': 6, 'linked': 7,
  'in-sync': 8, 'not-pushed': 9, 'no-deploy': 10
}
if mode == 'skills':
  items.sort(key=lambda a: (
    str((a.get('source') or {}).get('repo', '') or '').lower(),
    str(a.get('id', '') or '').lower()
  ))
else:
  items.sort(key=lambda a: (order.get(a.get('state',{}).get('sync',''), 99), a.get('id','')))

if not show_no_deploy:
  items = [a for a in items if a.get('state', {}).get('sync') != 'no-deploy']

if query:
  def matches(item):
    fields = [
      str(item.get('id', '') or ''),
      str((item.get('root_meta') or {}).get('name', '') or ''),
      str((item.get('root_meta') or {}).get('description', '') or ''),
      str((item.get('deploy') or {}).get('name', '') or ''),
      str((item.get('deploy') or {}).get('description', '') or ''),
    ]
    hay = ' '.join(fields).lower()
    return query in hay
  items = [a for a in items if matches(a)]

current_states = {'installed', 'linked', 'in-sync'}
current = sum(1 for a in items if a.get('state',{}).get('sync') in current_states)
actionable = sum(1 for a in items if a.get('state',{}).get('sync') in ('ready', 'outdated', 'not-pushed'))
invalid = sum(1 for a in items if a.get('state',{}).get('sync') in ('invalid', 'collision'))

if not items:
    print(f'  {label}')
    print()
    print(f'  {\"Mode\":<12} {mode}')
    if mode == 'agents':
        print(f'  {\"Platform\":<12} {platform}')
        print(f'  {\"Scope\":<12} {scope}')
        print(f'  {\"Runtime\":<12} {runtime}')
    print(f'  {\"Library\":<12} {db}')
    print(f'  {\"GitHub\":<12} {gh_mode or \"disabled\"}')
    print(f'  {\"Filter\":<12} {query or \"none\"}')
    print()
    print(f'  {\"Summary\":<12} 0 total, 0 current, 0 actionable, 0 invalid')
    print()
    print('  (no entries)')
    sys.exit(0)

if show_all or len(items) <= limit:
    visible = items
else:
    # In compact mode, make sure the first page exposes every present status
    # before filling the remaining slots in the normal sorted order.
    visible = []
    used = set()
    seen_states = set()

    for idx, item in enumerate(items):
        state = item.get('state', {}).get('sync', '?')
        if state in seen_states:
            continue
        visible.append(item)
        used.add(idx)
        seen_states.add(state)
        if len(visible) >= limit:
            break

    if len(visible) < limit:
        for idx, item in enumerate(items):
            if idx in used:
                continue
            visible.append(item)
            if len(visible) >= limit:
                break

    # Restore the normal list ordering for the compact subset.
    visible.sort(key=lambda a: (order.get(a.get('state', {}).get('sync', ''), 99), a.get('id', '')))

hidden = max(0, len(items) - len(visible))

STATE_COLOR = {
  'installed': C['green'],
  'linked': C['green'],
  'in-sync': C['green'],
  'outdated': C['yellow'],
  'ready': C['cyan'],
  'not-pushed': C['cyan'],
  'unmanaged': C['yellow'],
  'invalid': C['bold'] + C['red'],
  'collision': C['bold'] + C['red'],
  'orphan': C['red'],
  'no-deploy': C['dim'],
}

print(f'  {label}')
print()
print(f'  {\"Mode\":<12} {mode}')
if mode == 'agents':
    print(f'  {\"Platform\":<12} {platform}')
    print(f'  {\"Scope\":<12} {scope}')
    print(f'  {\"Runtime\":<12} {runtime}')
print(f'  {\"Library\":<12} {db}')
print(f'  {\"GitHub\":<12} {gh_mode or \"disabled\"}')
print(f'  {\"Filter\":<12} {query or \"none\"}')
print()
print(f'  {\"Summary\":<12} {len(items)} total, {current} current, {actionable} actionable, {invalid} invalid')
print()

def _skill_symbol(sync):
    return {
      'installed': '✓',
      'linked': '↗',
      'in-sync': '✓',
      'outdated': '~',
      'ready': '○',
      'not-pushed': '○',
      'unmanaged': '!',
      'invalid': 'x',
      'collision': 'x',
      'orphan': '?',
      'no-deploy': '-',
    }.get(sync, '?')

if mode == 'skills':
    direct = [item for item in visible if not ((item.get('source') or {}).get('repo') or '').strip()]
    grouped = {}
    for item in visible:
        repo = ((item.get('source') or {}).get('repo') or '').strip()
        if not repo:
            continue
        grouped.setdefault(repo, []).append(item)

    for item in direct:
        sync = item.get('state', {}).get('sync', '?')
        sym = _skill_symbol(sync)
        color = STATE_COLOR.get(sync, '')
        reset = C['reset'] if color else ''
        print(f'  {color}{sym}  {item.get(\"id\", \"?\"):<28} {sync}{reset}')

    for repo in sorted(grouped, key=lambda s: s.lower()):
        print(f'  {C[\"dim\"]}○  {repo}/{C[\"reset\"]}')
        for item in grouped[repo]:
            sync = item.get('state', {}).get('sync', '?')
            sym = _skill_symbol(sync)
            color = STATE_COLOR.get(sync, '')
            reset = C['reset'] if color else ''
            print(f'  {color}   {sym}  {item.get(\"id\", \"?\"):<25} {sync}{reset}')
else:
    for item in visible:
        sync = item.get('state', {}).get('sync', '?')
        sym = _skill_symbol(sync)
        color = STATE_COLOR.get(sync, '')
        reset = C['reset'] if color else ''
        print(f'  {color}{sym}  {item.get(\"id\", \"?\"):<28} {sync}{reset}')

if hidden:
    print()
    print(f'  {C[\"dim\"]}... {hidden} more hidden. Press e to expand.{C[\"reset\"]}')
" 2>/dev/null
}

